---
interface Props {
  name: string;
  year: number;
  era: string;
  slug: string;
  image?: string;
  tagline: string;
}

const { name, year, era, slug, image, tagline } = Astro.props;
---

<a href={`/item/${slug}`} class="item-card">
  <div class="card-image">
    {image
      ? <img src={image} alt={name} loading="lazy" />
      : <div class="card-image-placeholder"><span>{name[0]}</span></div>
    }
  </div>
  <div class="card-body">
    <div class="card-meta">
      <span class="card-year">{year}</span>
      <span class="card-era">{era}</span>
    </div>
    <h2 class="card-name">{name}</h2>
    <p class="card-tagline">{tagline}</p>
  </div>
</a>

<style>
  .item-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    transition: border-color 0.2s, transform 0.2s;
    overflow: hidden;
  }

  .item-card:hover {
    border-color: var(--color-accent-dim);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-surface-raised);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .item-card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 3rem;
    color: var(--color-text-muted);
  }

  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .card-year {
    color: var(--color-accent);
  }

  .card-era {
    color: var(--color-text-muted);
  }

  .card-name {
    font-size: 1.2rem;
  }

  .card-tagline {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
</style>
