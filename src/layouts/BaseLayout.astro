---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A personal archive of objects that marked turning points in civilization." } = Astro.props;
const path = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Museum of Civilization</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-logo" aria-label="Museum of Civilization — Home">
          <img src="/images/MoC Logo 4_small.jpg" alt="Museum of Civilization" />
        </a>
        <nav class="site-nav">
          <a href="/" class={path === '/' ? 'active' : ''}>Home</a>
          <a href="/collection" class={path.startsWith('/collection') || path.startsWith('/item') ? 'active' : ''}>Collection</a>
          <a href="/timeline" class={path === '/timeline' ? 'active' : ''}>Timeline</a>
          <a href="/play" class={path === '/play' ? 'active' : ''}>Play</a>
          <a href="/about" class={path === '/about' ? 'active' : ''}>About</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-col footer-nav">
          <span class="footer-heading">Explore</span>
          <nav>
            <a href="/collection">Collection</a>
            <a href="/timeline">Timeline</a>
            <a href="/play">Play</a>
            <a href="/about">About</a>
          </nav>
        </div>
        <div class="footer-col footer-brand">
          <a href="/" class="footer-wordmark">Museum of Civilization</a>
          <p class="footer-tagline">The world changed. These are objects that changed mine.</p>
        </div>
        <div class="footer-col footer-meta">
          <span class="footer-heading">Est. 2026</span>
          <p>A personal archive assembled while civilization is still running.</p>
        </div>
      </div>
      <div class="footer-base">
        <p>&copy; {new Date().getFullYear()} Museum of Civilization</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem var(--page-padding);
    position: sticky;
    top: 0;
    background: rgba(13, 13, 13, 0.95);
    backdrop-filter: blur(8px);
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-logo {
    display: block;
    height: 40px;
    flex-shrink: 0;
  }

  .site-logo img {
    height: 100%;
    width: auto;
    display: block;
    border-radius: 6px;
  }

  .site-nav {
    display: flex;
    gap: 2rem;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .site-nav a {
    color: var(--color-text-muted);
  }

  .site-nav a:hover {
    color: var(--color-accent);
  }

  .site-nav a.active {
    color: var(--color-accent);
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 6rem;
    background: var(--color-surface);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3.5rem var(--page-padding) 2.5rem;
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 2rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-heading {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  /* Nav column */
  .footer-nav nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-nav a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer-nav a:hover {
    color: var(--color-accent);
  }

  /* Brand column */
  .footer-brand {
    align-items: center;
    text-align: center;
  }

  .footer-wordmark {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--color-text);
    letter-spacing: 0.03em;
  }

  .footer-wordmark:hover {
    color: var(--color-accent);
  }

  .footer-tagline {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    font-style: italic;
    max-width: 280px;
  }

  /* Meta column */
  .footer-meta {
    align-items: flex-end;
    text-align: right;
  }

  .footer-meta p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* Bottom strip */
  .footer-base {
    border-top: 1px solid var(--color-border);
    padding: 1rem var(--page-padding);
    text-align: center;
  }

  .footer-base p {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  @media (max-width: 700px) {
    .footer-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-brand,
    .footer-meta {
      align-items: center;
      text-align: center;
    }

    .footer-nav nav {
      align-items: center;
    }
  }
</style>
